---
import '../styles/global.css';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Marc &amp; Jen - August 14, 2026</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Beau+Rivage&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,500;1,600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Jost:wght@400;500;600&display=swap" rel="stylesheet" />
    <script defer async data-host="marcandjen.site" src="https://liteanalytics.com/lite.js"></script>
  </head>
  <body>
<audio id="wedding-audio" src="/handa-na.mp3" preload="auto" loop></audio>
<div class="music-control" id="music-control">
  <button class="music-toggle" id="music-toggle" type="button" aria-pressed="false" aria-label="Play background music"><span class="music-icon" aria-hidden="true">Play</span><span class="music-text">Music</span></button>
  <label class="volume-control" for="music-volume">
    <span class="volume-text">Volume</span>
    <input id="music-volume" type="range" min="0" max="100" step="1" value="25" aria-label="Background music volume" />
  </label>
</div>
<nav class="site-nav" id="nav">
  <a href="#hero" class="nav-mark" aria-label="Marc and Jen wedding home">
    <img src="/mj-wedding-logo.svg" alt="Marc and Jen wedding monogram">
  </a>
  <ul class="nav-links" id="nav-links">
    <li><a href="#story">Our Story</a></li>
    <li><a href="#details">The Details</a></li>
    <li><a href="#entourage">Entourage</a></li>
    <li><a href="#attire">Attire</a></li>
  </ul>
  <button class="nav-toggle" id="nav-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-links">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke-width="1.6"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
  </button>
</nav>

<!-- ============ HERO ============ -->
<header class="hero" id="hero">
  <div class="hero-bg">
    <img src="data:image/jpeg;base64," alt="Marc and Jen, arms around each other, looking up at the lit facade of the wedding venue at night">
  </div>
  <div class="corner" style="top:6%;left:3%;width:140px;">
    <svg viewBox="0 0 140 160" fill="none">
      <path class="crest-sprig" d="M70 150 C 60 110, 30 90, 8 70"/>
      <path class="crest-sprig" d="M70 150 C 75 100, 60 70, 40 40"/>
      <path class="crest-sprig" d="M70 150 C 85 110, 100 95, 125 78"/>
      <circle cx="8" cy="70" r="2.4" fill="none" stroke="var(--gold)"/>
      <circle cx="40" cy="40" r="2.4" fill="none" stroke="var(--gold)"/>
      <circle cx="125" cy="78" r="2.4" fill="none" stroke="var(--gold)"/>
    </svg>
  </div>

  <img class="crest-logo" src="/mj-wedding-logo.svg" alt="Marc and Jen wedding monogram">

  <p class="hero-eyebrow">together with our families</p>
  <h1 class="hero-names">Marc Jherico<span class="hero-amp">&amp;</span>Jenny&nbsp;Ruth</h1>
  <p class="hero-date">Friday &middot; August 14, 2026 &middot; Villa Juanita</p>

  <p class="hero-verse">"When the time is right, I, the Lord, will make it happen."<cite>Isaiah 60:22</cite></p>

  <div class="countdown" id="countdown" aria-label="Time remaining until the wedding">
    <div class="cell"><div class="num" id="cd-days">00</div><div class="unit">Days</div></div>
    <div class="cell"><div class="num" id="cd-hours">00</div><div class="unit">Hours</div></div>
    <div class="cell"><div class="num" id="cd-mins">00</div><div class="unit">Mins</div></div>
    <div class="cell"><div class="num" id="cd-secs">00</div><div class="unit">Secs</div></div>
  </div>

  <div class="scroll-cue">
    <span>Open Invitation</span>
    <svg width="16" height="20" viewBox="0 0 16 20" fill="none"><path d="M8 1v16M2 11l6 6 6-6" stroke="var(--gold-deep)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</header>

<main>

  <!-- ============ PRENUPTIAL EDITORIAL ============ -->
  <section class="section editorial-story" id="story" aria-labelledby="editorial-title">
    <div class="editorial-cover reveal">
      <img src="/images/editorial/editorial-01.jpg" alt="Marc and Jen prenuptial portrait">
      <div class="editorial-cover-copy">
        <p class="label">Pre-nuptial Editorial</p>
        <h2 id="editorial-title">A Love That<br>Feels Like Home</h2>
        <p>Photographed in the Philippines</p>
      </div>
    </div>

    <div class="wrap editorial-intro reveal">
      <div class="eyebrow"><span class="rule"></span><span class="label">Before The Big Day</span><span class="rule"></span></div>
      <p class="story-text center">An editorial chapter for Marc and Jen: quiet gestures, golden-hour laughter, and the promise that carries them toward August 14, 2026.</p>
    </div>

    <div class="editorial-chapter wrap reveal">
      <div class="editorial-chapter-label">
        <span>Chapter I</span>
        <i></i>
        <span>The White Series</span>
      </div>

      <div class="editorial-grid editorial-grid-featured">
        <button class="editorial-frame editorial-feature" type="button"><img src="/images/editorial/editorial-02.jpg" alt="Marc and Jen beside a lamppost"></button>
        <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-03.jpg" alt="Marc and Jen evening outdoor portrait"></button>
        <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-04.jpg" alt="Marc and Jen walking by the pool"></button>
      </div>

      <div class="editorial-grid editorial-grid-halves">
        <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-05.jpg" alt="Marc and Jen rose kiss moment"></button>
        <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-06.jpg" alt="Marc and Jen picnic evening session"></button>
      </div>
    </div>

    <aside class="editorial-quote reveal" aria-label="Editorial quote">
      <div>
        <span class="quote-mark">&ldquo;</span>
        <p>Two people,<br>one story,<br>forever unfolding.</p>
      </div>
      <i></i>
      <div>
        <span class="label">The Detail</span>
        <p>She extended her hand, and in that single gesture a whole future came into focus. Every love story has its symbol.</p>
      </div>
    </aside>

    <div class="editorial-ring reveal">
      <div class="wrap editorial-ring-inner">
        <div class="editorial-ring-copy">
          <h3>The ring.<br>The promise.<br>The beginning.</h3>
          <p>Held close and shown to the world, the quiet confidence of two people who have chosen each other completely.</p>
        </div>
        <div class="editorial-grid editorial-grid-halves">
          <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-07.jpg" alt="Jen displaying her engagement ring"></button>
          <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-08.jpg" alt="Jen's engagement ring on Marc's shoulder"></button>
        </div>
      </div>
    </div>

    <div class="editorial-chapter editorial-cream-highlight wrap reveal">
      <div class="editorial-chapter-label">
        <span>Chapter II</span>
        <i></i>
        <span>The Cream Series</span>
      </div>

      <div class="editorial-highlight-copy">
        <p class="label">Featured Moments</p>
        <h3>Light, laughter, and the quiet look of home.</h3>
      </div>

      <div class="editorial-grid editorial-grid-reverse">
        <button class="editorial-frame editorial-feature-card" type="button"><img src="/images/editorial/editorial-09.jpg" alt="Marc and Jen on a park bench"></button>
        <button class="editorial-frame editorial-feature-card" type="button"><img src="/images/editorial/editorial-10.jpg" alt="Marc and Jen bench golden hour portrait"></button>
        <button class="editorial-frame editorial-feature editorial-hero-card" type="button"><img src="/images/editorial/editorial-11.jpg" alt="Marc and Jen swing moment"></button>
      </div>

      <div class="editorial-grid editorial-grid-thirds">
        <button class="editorial-frame editorial-feature-card" type="button"><img src="/images/editorial/editorial-12.jpg" alt="Marc and Jen poolside portrait"></button>
        <button class="editorial-frame editorial-feature-card" type="button"><img src="/images/editorial/editorial-13.jpg" alt="Marc and Jen park swing series"></button>
        <button class="editorial-frame editorial-feature-card" type="button"><img src="/images/editorial/editorial-14.jpg" alt="Marc and Jen tender pool moment"></button>
      </div>
    </div>

    <button class="editorial-panorama reveal" type="button">
      <img src="/images/editorial/editorial-15.jpg" alt="Marc giving Jen a piggyback ride">
      <span>Joy, unscripted</span>
    </button>

    <div class="wrap editorial-strip reveal" aria-label="Editorial closing photos">
      <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-16.jpg" alt="Marc and Jen prenuptial detail photo"></button>
      <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-17.jpg" alt="Marc and Jen prenuptial candid photo"></button>
      <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-18.jpg" alt="Marc and Jen prenuptial portrait detail"></button>
      <button class="editorial-frame" type="button"><img src="/images/editorial/editorial-19.jpg" alt="Marc and Jen prenuptial closing portrait"></button>
    </div>

    <div class="wrap editorial-closing">
      <p class="story-text center reveal">Real and expressive, this is the beginning of Marc and Jen's forever: two lives, two families, and one promise as Jenny Ruth joyfully takes the Sumilang surname.</p>

      <div class="video-frame reveal" data-video-src="/marc-jenny-save-the-date.mp4" data-video-poster="/images/editorial/editorial-15.jpg">
        <button class="video-play" type="button" aria-label="Play save-the-date video">
          <img src="/images/editorial/editorial-15.jpg" alt="Marc and Jen save-the-date video poster" loading="lazy">
          <span class="video-play-icon" aria-hidden="true"></span>
          <span class="video-play-text">Play Save the Date</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ============ INVITATION / DETAILS ============ -->
  <section class="section parallax-section" id="details">
    <div class="wrap">
      <div class="arch-card reveal">
        <img class="crest-logo small" src="/mj-wedding-logo.svg" alt="Marc and Jen wedding monogram">
        <div class="center">
          <p class="display-title" style="font-size:1.15rem;font-style:normal;font-family:var(--font-body);color:var(--taupe);">With the grace of God and the blessing of our parents, we</p>
          <h2 class="script-title" style="font-size:clamp(2rem,5vw,2.8rem);margin:0.6rem 0;">Marc Jherico &amp; Jenny Ruth</h2>
          <p style="font-style:italic;color:var(--ink);max-width:42ch;margin:0 auto;">request the honor of your presence as we celebrate our love and marriage</p>
        </div>

        <div class="divider-sprig">
          <svg width="180" height="20" viewBox="0 0 180 20"><line x1="0" y1="10" x2="70" y2="10" stroke="var(--gold)" stroke-width="1"/><circle cx="90" cy="10" r="3" fill="var(--gold)"/><line x1="110" y1="10" x2="180" y2="10" stroke="var(--gold)" stroke-width="1"/></svg>
        </div>

        <div class="details-grid">
          <div class="detail-block center">
            <p class="label">Ceremony &amp; Reception</p>
            <h3>Friday, August 14, 2026</h3>
            <p>3:00 in the afternoon</p>
            <p class="muted">Please arrive 30 minutes early</p>
          </div>
          <div class="rule-v"></div>
          <div class="detail-block center">
            <p class="label">Venue</p>
            <h3>Villa Juanita</h3>
            <p>191 Look 1, Malolos, Bulacan</p>
            <p class="muted">Semi-formal attire requested</p>
          </div>
        </div>

        <div class="btn-row">
          <a class="btn btn-solid" href="https://www.google.com/maps/search/?api=1&amp;query=Villa+Juanita+191+Look+1+Malolos+Bulacan" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-7.58 8-13a8 8 0 1 0-16 0c0 5.42 8 13 8 13Z"/><circle cx="12" cy="9" r="2.6"/></svg>
            Get Directions
          </a>
          <a class="btn btn-ghost" href="https://calendar.google.com/calendar/render?action=TEMPLATE&amp;text=Marc+%26+Jen%27s+Wedding&amp;dates=20260814T070000Z/20260814T110000Z&amp;details=Ceremony+and+reception+at+Villa+Juanita,+191+Look+1,+Malolos,+Bulacan&amp;location=Villa+Juanita,+191+Look+1,+Malolos,+Bulacan" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4M8 3v4M3 10h18"/></svg>
            Add to Calendar
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ENTOURAGE ============ -->
  <section class="section" id="entourage">
    <div class="wrap">
      <div class="center reveal">
        <div class="eyebrow"><span class="rule"></span><span class="label">With Gratitude</span><span class="rule"></span></div>
        <h2 class="display-title">The Entourage</h2>
        <p style="color:var(--taupe);font-style:italic;margin-top:0.3rem;">Mirandilla &middot; Sumilang</p>
      </div>

      <div class="arch-card reveal" style="margin-top:var(--sp-4);">
        <div class="role-grid">
          <div class="role"><span class="label">Parents of the Bride</span><p class="names">Mrs. Elenita S. Mirandilla<br>Mr. Melchor M. Mirandilla</p></div>
          <div class="role"><span class="label">Parents of the Groom</span><p class="names">Mrs. Marian R. Sumilang<br>Mr. Enrique R. Sumilang</p></div>
        </div>

        <p class="sub-section-title">Officiating Minister</p>
        <div class="role center"><p class="names">Ptr. Jon Sanoy</p></div>

        <p class="sub-section-title">Principal Sponsors</p>
        <div class="role-grid">
          <div class="role"><p class="names">
            Dr. Rosemarie Sibbaluca Guirre<br>
            Mrs. Paula Cruz<br>
            Mrs. Marifel R. Ramirez<br>
            Mrs. Vilma Sumilang<br>
            Mrs. Mita Tan
          </p></div>
          <div class="role"><p class="names">
            Mr. Laurence Enriquez Guirre<br>
            Mr. Jwilliam Cruz<br>
            Mr. Rodrigo Aguilar
          </p></div>
        </div>

        <div class="divider-sprig"><svg width="120" height="14" viewBox="0 0 120 14"><circle cx="60" cy="7" r="2.5" fill="var(--gold)"/></svg></div>

        <div class="role-grid">
          <div class="role"><span class="label">Maid of Honor</span><p class="names">Jazmine Sumilang</p></div>
          <div class="role"><span class="label">Best Man</span><p class="names">Jay Micheal Cantilla</p></div>
        </div>

        <p class="sub-section-title">Secondary Sponsors</p>
        <div class="role-grid wide">
          <div class="role"><span class="label">Veil</span><p class="names">Praise Joy S. Mirandilla<br>Jefferson R. Sumilang</p></div>
          <div class="role"><span class="label">Jar</span><p class="names">Aivie R. Ramirez<br>Mandy Villcastin</p></div>
          <div class="role"><span class="label">Cord</span><p class="names">Patricia Mari C. Santos<br>Christian S. Mirandilla</p></div>
        </div>

        <div class="role-grid" style="margin-top:var(--sp-4);">
          <div class="role"><span class="label">Bridesmaids</span><p class="names">
            Praise Joy S. Mirandilla<br>Patricia Mari C. Santos<br>Annabelle C. Dilag<br>
            Acelyn DP. Asiddao<br>Rachel Joy U. Santos<br>Aivie R. Ramirez
          </p></div>
          <div class="role"><span class="label">Groomsmen</span><p class="names">
            Jefferson R. Sumilang<br>Christian S. Mirandilla<br>Ryan Pascual<br>
            Mandy Villcastin<br>Yuan Lopez<br>Jay Cruz
          </p></div>
        </div>

        <div class="role-grid wide" style="margin-top:var(--sp-4);">
          <div class="role"><span class="label">Coin Bearer</span><p class="names">Aivan Ramirez</p></div>
          <div class="role"><span class="label">Bible Bearer</span><p class="names">Raymund Ivan Lopez</p></div>
          <div class="role"><span class="label">Ring Bearer</span><p class="names">Mark Emmanuel Mirandilla</p></div>
        </div>

        <p class="sub-section-title">Flower Girls</p>
        <div class="role center"><p class="names">
          Zipporah Prail Mirandilla &middot; Marzella Ishie Mirandilla<br>
          Martha Rodriguez &middot; Bertha Rodriguez
        </p></div>
      </div>
    </div>
  </section>

  <!-- ============ ATTIRE + GIFT ============ -->
  <section class="section" id="attire">
    <div class="wrap">
      <div class="center reveal">
        <div class="eyebrow"><span class="rule"></span><span class="label">A Few Notes</span><span class="rule"></span></div>
        <h2 class="display-title">Finer Details</h2>
      </div>

      <div class="arch-card reveal" style="margin-top:var(--sp-4);">
        <div class="finer-grid">
          <div>
            <p class="label">Attire Guide</p>
            <h3 style="font-family:var(--font-display);font-style:italic;font-weight:600;font-size:1.5rem;color:var(--umber);margin:0.4rem 0;">Semi-Formal Attire</h3>
            <p class="muted" style="color:var(--taupe);">We'd love to see you dressed in the colors of our wedding theme.</p>
            <div class="swatches" aria-label="Suggested color palette">
              <span class="swatch" style="background:#F3EBDD;" title="Cream"></span>
              <span class="swatch" style="background:#E1CBA6;" title="Beige"></span>
              <span class="swatch" style="background:#C9A063;" title="Gold sand"></span>
              <span class="swatch" style="background:#9C8275;" title="Mauve taupe"></span>
            </div>
            <div class="silhouettes" aria-hidden="true">
              <svg viewBox="0 0 34 60" fill="none" stroke="var(--umber)" stroke-width="1.1"><path d="M17 6c-5 0-7 5-6 9 0 0-6 4-6 14v25h24V29c0-10-6-14-6-14 1-4-1-9-6-9Z"/></svg>
              <svg viewBox="0 0 34 60" fill="none" stroke="var(--umber)" stroke-width="1.1"><circle cx="17" cy="9" r="5"/><path d="M9 22l8-6 8 6v6l-5-2v28h-6V20l-5 2z"/></svg>
              <svg viewBox="0 0 34 60" fill="none" stroke="var(--umber)" stroke-width="1.1"><circle cx="17" cy="8" r="5"/><path d="M7 18c4 5 16 5 20 0v8l-5 4v24h-10V30l-5-4z"/></svg>
              <svg viewBox="0 0 34 60" fill="none" stroke="var(--umber)" stroke-width="1.1"><circle cx="17" cy="9" r="5"/><path d="M10 21l7-5 7 5v9h-3v24h-8V30h-3z"/></svg>
            </div>
          </div>

          <div>
            <p class="label">Gift Guide</p>
            <h3 style="font-family:var(--font-display);font-style:italic;font-weight:600;font-size:1.5rem;color:var(--umber);margin:0.4rem 0;">With Love, No Boxes</h3>
            <p class="gift-text">Blessed by the Lord and by your love, your prayers are the greatest gift of all. If you wish to help us begin our new life together, a monetary gift or a surprise of your own choosing would mean the world.</p>
          </div>
        </div>

        <div class="divider-sprig"><svg width="220" height="16" viewBox="0 0 220 16"><line x1="0" y1="8" x2="90" y2="8" stroke="var(--gold)" stroke-width="1"/><circle cx="110" cy="8" r="3" fill="var(--gold)"/><line x1="130" y1="8" x2="220" y2="8" stroke="var(--gold)" stroke-width="1"/></svg></div>

        <p class="label center" style="display:block;">Reminders</p>
        <div class="reminders">
          <div class="reminder">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke-width="1.4"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            <span>Be On Time</span>
          </div>
          <div class="reminder">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke-width="1.4"><path d="M12 21s-7-4.6-9.3-9A5.4 5.4 0 0 1 12 6a5.4 5.4 0 0 1 9.3 6c-2.3 4.4-9.3 9-9.3 9Z"/></svg>
            <span>Have Fun</span>
          </div>
          <div class="reminder">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke-width="1.4"><path d="M20 6 9 17l-5-5"/></svg>
            <span>Stay Till The End</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</main>

<footer class="reveal">
  <img class="crest-logo footer-logo" src="/mj-wedding-logo.svg" alt="Marc and Jen wedding monogram">
  <h2 class="script-title">See you there</h2>
  <p class="note">Our hearts are overflowing with gratitude - we're so honored to share this chapter with the people who mean the world to us.</p>
  <p class="credit">Marc &amp; Jen &middot; August 14, 2026 &middot; Villa Juanita, Malolos</p>
</footer>

<div class="lightbox" id="image-lightbox" role="dialog" aria-modal="true" aria-label="Expanded photo">
  <button class="lightbox-btn lightbox-close" type="button" id="lightbox-close" aria-label="Close image">
    <svg viewBox="0 0 24 24"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <button class="lightbox-btn lightbox-prev" type="button" id="lightbox-prev" aria-label="Previous image">
    <svg viewBox="0 0 24 24"><path d="M15 5l-7 7 7 7"/></svg>
  </button>
  <img id="lightbox-image" alt="">
  <button class="lightbox-btn lightbox-next" type="button" id="lightbox-next" aria-label="Next image">
    <svg viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
  </button>
</div>


    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>



